# ==============================================================================
# AtlasMarket — Platform API (Node.js backend) environment
# ==============================================================================
# Copy this file to `platform-api/.env` and fill in the values below.
# NEVER commit the real .env file. Keep all secrets on the server.

# ---- Server -------------------------------------------------------------------
PORT=8787
ATLASMARKET_DATA_FILE=./platform-api/data/store.json
ATLASMARKET_SESSION_TTL_HOURS=720
ATLASMARKET_PUBLIC_APP_URL=http://localhost:19006
ATLASMARKET_STRIPE_MODE=billing

# ---- Market data provider -----------------------------------------------------
# Finnhub is the default provider (generous free tier, covers global markets).
#
#  1. Sign up:             https://finnhub.io/register
#  2. Open your dashboard: https://finnhub.io/dashboard
#  3. Copy the API Key and paste it below.
#
# You can swap providers by pointing MARKET_DATA_API_BASE at another REST API
# that follows the same quote/candles/news shape.
MARKET_DATA_PROVIDER=finnhub
MARKET_DATA_API_BASE=https://finnhub.io/api/v1
MARKET_DATA_API_KEY=replace-with-finnhub-key
NEWS_DATA_API_BASE=https://finnhub.io/api/v1

# ---- Stripe -------------------------------------------------------------------
# Required when ATLASMARKET_STRIPE_MODE=billing or =funding.
#
#  1. Create / log in:        https://dashboard.stripe.com/register
#  2. Secret + publishable:   https://dashboard.stripe.com/apikeys
#       - STRIPE_SECRET_KEY goes here (starts with sk_test_ or sk_live_)
#       - Put the matching pk_... in the client .env as STRIPE_PUBLISHABLE_KEY
#  3. Create a recurring Price for your plan:
#       https://dashboard.stripe.com/products   -> "Add product" -> recurring
#       Copy the price_... id into STRIPE_PRICE_ID
#  4. Webhook signing secret:
#       https://dashboard.stripe.com/webhooks
#       "Add endpoint" -> URL: https://YOUR-API-DOMAIN/v1/webhooks/stripe
#       Listen for: checkout.session.completed, customer.subscription.*,
#                   invoice.paid, invoice.payment_failed
#       Copy the whsec_... signing secret into STRIPE_WEBHOOK_SECRET
#  5. (Optional) A default test customer id to speed up local demos:
#       https://dashboard.stripe.com/customers
#
# For local webhook testing use the Stripe CLI:
#       stripe listen --forward-to localhost:8787/v1/webhooks/stripe
#       https://stripe.com/docs/stripe-cli
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_DEFAULT_CUSTOMER_ID=cus_replace_me

# Optional: a pre-built Stripe Payment Link / hosted funding page used when
# ATLASMARKET_STRIPE_MODE=funding and you'd rather redirect to Stripe's hosted
# flow than create a Checkout Session per click.
#   https://dashboard.stripe.com/payment-links
ATLASMARKET_STRIPE_FUNDING_URL=https://buy.stripe.com/replace-me

# ---- CORS / client origin -----------------------------------------------------
# Comma-separated list of origins allowed to call this API from the browser.
ATLASMARKET_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:19001
