# ==============================================================================
# AtlasMarket — Client (Expo / React Native Web) environment
# ==============================================================================
# Copy this file to `.env` and fill in the values below.
# All client-side values are safe to ship publicly. Keep secret keys on the
# platform-api server only (see platform-api/.env.example).

# ---- Platform API gateway -----------------------------------------------------
# Where the client should talk for auth, workspace sync, market proxy and Stripe.
# For local dev use http://localhost:8787.
# For production, point at your deployed backend (e.g. https://api.yourdomain.com).
ATLASMARKET_API_BASE=http://localhost:8787

# Public URL of the web app (used by Stripe return_url / success_url etc.)
ATLASMARKET_PUBLIC_APP_URL=http://localhost:19006

# How the client should fetch market data:
#   proxy   = go through the platform API (recommended, keeps keys server-side)
#   direct  = call the provider straight from the browser (demo only, exposes key)
ATLASMARKET_MARKET_DATA_MODE=proxy

# How Stripe is wired into the app:
#   disabled = hide Stripe UI
#   billing  = subscription / plan upgrade flow (Checkout + Customer Portal)
#   funding  = brokerage-style account funding flow
ATLASMARKET_STRIPE_MODE=billing

# ---- Optional: direct provider fallback (development only) --------------------
# If ATLASMARKET_MARKET_DATA_MODE=direct these will be used from the browser.
# Get a free Finnhub key: https://finnhub.io/register
MARKET_DATA_PROVIDER=finnhub
MARKET_DATA_API_BASE=https://finnhub.io/api/v1
MARKET_DATA_API_KEY=replace-with-finnhub-key
NEWS_DATA_API_BASE=https://finnhub.io/api/v1
MARKET_DATA_REFRESH_INTERVAL_MS=15000

# Stripe publishable key (pk_test_... or pk_live_...) — safe for the client.
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Never put Stripe secret keys, webhook signing secrets, or broker credentials
# in this file. Those live in platform-api/.env.
